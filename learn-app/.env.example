# Copy this file to .env.local and fill in the values, then restart the dev server.

# Supabase → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Any long random string — signs the session cookie.
SESSION_SECRET=change-me-to-a-long-random-string

# Teacher login (used on the login page with "I'm the teacher").
TEACHER_USERNAME=teacher
TEACHER_PASSWORD=choose-a-strong-password
